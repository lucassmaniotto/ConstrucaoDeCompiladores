\pard\qc\sb240\sa240\sl360\slmult1\b\f0\fs24 PROJETO 2: Constru\u250?\u250?o de Analisador Sint\u250?tico\b0\par
\pard\qc\sb240\sa240\sl360\slmult1\f0\fs24 \par
